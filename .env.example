# =============================================================================
# Pipedrive MCP Server - LOCAL development environment
#
# Copy this file to .env (which is gitignored). This repo's .env is loaded ONLY
# when you run the server from THIS directory (npm run dev / start /
# smoke:installments), because src loads dotenv from the current working dir.
#
# It does NOT affect anyone who installs the published package: consumers run
# `npx -y pipedrive-mcp-server` and supply the key via their own .mcp.json "env"
# block, which OVERRIDES .env (dotenv never overwrites an already-set variable).
# Precedence: .mcp.json env (or an exported shell var) > .env.
#
#   => Put a SANDBOX (throwaway) key here, never the production key.
#      The production key belongs only in the production runner's .mcp.json
#      "env" block or secret store, not in a developer working copy.
# =============================================================================

# Pipedrive personal API token (40 characters).
# Get it from: Pipedrive Settings > Personal preferences > API
# Use a SANDBOX account token for local dev. Deal installments require a
# Growth-plan-or-higher account; see docs/installments-smoke-test.md.
PIPEDRIVE_API_KEY=your-40-character-sandbox-api-key-here

# Enable destructive operations (delete tools). Default: false.
# Required locally for the full installments smoke (npm run smoke:installments).
# Leave disabled unless you intend to delete records.
# PIPEDRIVE_ENABLE_DESTRUCTIVE=true
