{
  "name": "@ckalima/pipedrive-mcp-server",
  "version": "2.0.0",
  "mcpName": "io.github.ckalima/pipedrive-mcp-server",
  "description": "MCP server for Pipedrive CRM integration with Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pipedrive-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "smoke:installments": "tsx scripts/smoke-installments.ts",
    "smoke:coverage": "tsx scripts/smoke-coverage.ts",
    "gen:docs": "tsx scripts/gen-docs.ts",
    "bundle:mcpb": "tsx scripts/build-mcpb.ts",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ckalima/pipedrive-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/ckalima/pipedrive-mcp-server/issues"
  },
  "homepage": "https://github.com/ckalima/pipedrive-mcp-server#readme",
  "keywords": [
    "mcp",
    "pipedrive",
    "crm",
    "claude",
    "ai",
    "model-context-protocol"
  ],
  "author": "ckalima",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "js-yaml": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
